[
  {
    "id": "page-metadata",
    "fields": [
      { "component": "text",      "name": "title",       "label": "Title" },
      { "component": "text",      "name": "description",  "label": "Description" },
      { "component": "reference", "name": "image",        "label": "Image" },
      { "component": "text",      "name": "robots",       "label": "Robots",
        "description": "Index control via robots" }
    ]
  },
  {
    "id": "image",
    "fields": [
      { "component": "reference", "name": "image",    "label": "Image",    "multi": false },
      { "component": "text",      "name": "imageAlt", "label": "Alt Text" }
    ]
  },
  {
    "id": "section",
    "fields": [
      {
        "component": "multiselect",
        "name": "style",
        "label": "Style",
        "options": [
          { "name": "Highlight",  "value": "highlight" },
          { "name": "Dark",       "value": "dark" },
          { "name": "Brand",      "value": "brand" },
          { "name": "Light BG",   "value": "light-bg" },
          { "name": "Full Width", "value": "full-width" }
        ]
      }
    ]
  },
  {
    "id": "announcement-bar",
    "fields": [
      {
        "component": "richtext",
        "name": "message1",
        "label": "Message 1",
        "valueType": "string",
        "required": true,
        "description": "First promo line. Supports bold and links."
      },
      {
        "component": "richtext",
        "name": "message2",
        "label": "Message 2 (optional)",
        "valueType": "string",
        "description": "Second promo line. Leave blank if not needed."
      }
    ]
  },
  {
    "id": "marquee",
    "fields": [
      {
        "component": "text",
        "name": "text",
        "label": "Ticker Text",
        "valueType": "string",
        "required": true,
        "description": "The scrolling text (repeated automatically). Use & to separate terms."
      },
      {
        "component": "boolean",
        "name": "classes_reverse",
        "label": "Reverse Direction",
        "valueType": "boolean",
        "description": "Scroll from left to right instead of right to left."
      }
    ]
  },
  {
    "id": "newsletter",
    "fields": [
      {
        "component": "text",
        "name": "heading",
        "label": "Heading",
        "valueType": "string",
        "required": true
      },
      {
        "component": "richtext",
        "name": "finePrint",
        "label": "Fine Print / Legal",
        "valueType": "string",
        "description": "Privacy disclaimer shown below the form."
      },
      {
        "component": "text",
        "name": "buttonLabel",
        "label": "Submit Button Label",
        "valueType": "string",
        "value": "sign up now"
      },
      {
        "component": "text",
        "name": "endpoint",
        "label": "POST Endpoint",
        "valueType": "string",
        "value": "/newsletter",
        "description": "Server-side URL that accepts { email } as JSON."
      }
    ]
  },
  {
    "id": "hero",
    "fields": [
      { "component": "reference", "name": "image",    "label": "Image",    "multi": false },
      { "component": "text",      "name": "imageAlt", "label": "Alt",      "value": "" },
      { "component": "text",      "name": "text",     "label": "Text",     "valueType": "string" }
    ]
  },
  {
    "id": "card",
    "fields": [
      { "component": "reference", "name": "image",    "label": "Image",     "multi": false },
      { "component": "text",      "name": "imageAlt", "label": "Image Alt", "multi": false },
      { "component": "richtext",  "name": "text",     "label": "Text",      "valueType": "string" }
    ]
  },
  {
    "id": "carousel-item",
    "fields": [
      { "component": "reference", "name": "backgroundImage",    "label": "Background Image", "multi": false },
      { "component": "text",      "name": "backgroundImageAlt", "label": "Background Image Alt" },
      { "component": "richtext",  "name": "text",               "label": "Text", "valueType": "string" }
    ]
  },
  {
    "id": "columns",
    "fields": [
      {
        "component": "number",
        "name": "columns",
        "label": "Number of Columns",
        "value": 3,
        "validation": { "numberMin": 1, "numberMax": 6 }
      }
    ]
  },
  {
    "id": "fragment",
    "fields": [
      { "component": "text", "name": "urlText", "label": "Fragment URL Text" },
      { "component": "text", "name": "url",     "label": "Fragment URL", "required": true }
    ]
  },
  {
    "id": "accordion-item",
    "fields": [
      { "component": "richtext", "name": "summary", "label": "Summary", "valueType": "string", "required": true },
      { "component": "richtext", "name": "text",    "label": "Text",    "valueType": "string", "required": true }
    ]
  },
  {
    "id": "quote",
    "fields": [
      { "component": "richtext", "name": "quote",  "label": "Quote",  "valueType": "string", "required": true },
      { "component": "text",     "name": "author", "label": "Author", "valueType": "string" }
    ]
  },
  {
    "id": "search",
    "fields": [
      { "component": "text", "name": "searchUrlText", "label": "Search URL Text", "valueType": "string" },
      { "component": "text", "name": "searchUrl",     "label": "Search URL",      "required": true }
    ]
  },
  {
    "id": "table",
    "fields": [
      { "component": "richtext", "name": "table", "label": "Table Content" }
    ]
  },
  {
    "id": "tabs-item",
    "fields": [
      { "component": "text",     "name": "name",    "label": "Tab Name", "valueType": "string" },
      { "component": "richtext", "name": "content", "label": "Content",  "valueType": "string" }
    ]
  },
  {
    "id": "video",
    "fields": [
      { "component": "boolean",  "name": "classes_autoplay", "label": "Autoplay Video",   "valueType": "boolean" },
      { "component": "text",     "name": "videoUrl",         "label": "Video URL",        "valueType": "string", "required": true },
      { "component": "text",     "name": "videoUrlText",     "label": "Video URL Text",   "valueType": "string" },
      { "component": "reference","name": "posterImage",      "label": "Poster Image",     "valueType": "string" }
    ]
  }
]
